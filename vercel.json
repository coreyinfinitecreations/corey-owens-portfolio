{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "studio.coreyowens.com"
        }
      ],
      "destination": "/studio"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "studio.coreyowens.com"
        }
      ],
      "destination": "/studio/:path*"
    }
  ]
}
